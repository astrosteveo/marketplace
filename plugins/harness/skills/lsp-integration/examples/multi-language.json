{
  "typescript": {
    "command": "typescript-language-server",
    "args": ["--stdio"],
    "settings": {
      "typescript": {
        "format": {
          "semicolons": "insert"
        }
      }
    },
    "restartOnCrash": true,
    "extensionToLanguage": {
      ".ts": "typescript",
      ".tsx": "typescriptreact",
      ".js": "javascript",
      ".jsx": "javascriptreact"
    }
  },
  "python": {
    "command": "pyright-langserver",
    "args": ["--stdio"],
    "restartOnCrash": true,
    "extensionToLanguage": {
      ".py": "python"
    }
  },
  "rust": {
    "command": "rust-analyzer",
    "restartOnCrash": true,
    "extensionToLanguage": {
      ".rs": "rust"
    }
  }
}
